naive bayes

from sklearn.datasets import fetch_20newsgroups
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.naive_bayes import MultinomialNB
from sklearn.pipeline import make_pipeline
from sklearn.metrics import accuracy_score, classification_report, ConfusionMatrixDisplay
import matplotlib.pyplot as plt

# Categories
categories = ['talk.religion.misc','soc.religion.christian','sci.space','comp.graphics']

# Load data
train = fetch_20newsgroups(subset='train', categories=categories)
test = fetch_20newsgroups(subset='test', categories=categories)

# Build & train model
model = make_pipeline(TfidfVectorizer(), MultinomialNB())
model.fit(train.data, train.target)

# Test prediction
labels = model.predict(test.data)

# Results
print("Accuracy:", accuracy_score(test.target, labels)*100)
print(classification_report(test.target, labels))

ConfusionMatrixDisplay.from_estimator(model, test.data, test.target,display_labels=test.target_names)
plt.show()

# Prediction function
def predict_category(text):
    return train.target_names[model.predict([text])[0]]

# Example predictions
print(predict_category('discussing islam vs atheism'))
print(predict_category('sending a payload to the ISS'))
print(predict_category('determining the screen resolution'))


K means 

 import pandas as pd
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans

# Load dataset
df = pd.read_csv(r'C:\MSC DA -ML Datasets (2024 -25 Batch)\Seed_Data.csv')
print(df.isna().sum())

# Select features
X = df[['LK', 'WK']]

# Initial plot
plt.scatter(X['LK'], X['WK'])
plt.xlabel('LK')
plt.ylabel('WK')
plt.show()

# Elbow method using inertia
inertia = []
for k in range(2, 12):
    model = KMeans(n_clusters=k)
    model.fit(X)
    inertia.append(model.inertia_)

plt.plot(range(2, 12), inertia, '-o')
plt.xlabel('K')
plt.ylabel('Inertia')
plt.show()

# Final clustering (k=3)
kmeans = KMeans(n_clusters=3)
kmeans.fit(X)

plt.scatter(X['LK'], X['WK'], c=kmeans.labels_)
plt.scatter(kmeans.cluster_centers_[:,0],
            kmeans.cluster_centers_[:,1])
plt.xlabel('LK')
plt.ylabel('WK')
plt.show()


PCA 

 import pandas as pd
import matplotlib.pyplot as plt
from sklearn.datasets import load_iris
from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA

# Load Iris dataset
iris = load_iris()
X = iris.data
y = iris.target

# Standardize the data
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# Apply PCA (2 Principal Components)
pca = PCA(n_components=2)
X_pca = pca.fit_transform(X_scaled)

# Convert to DataFrame
df_pca = pd.DataFrame(X_pca, columns=['PC1', 'PC2'])

# Print explained variance
print("Explained Variance Ratio:", pca.explained_variance_ratio_)

# Plot PCA result
plt.figure(figsize=(8,6))
plt.scatter(df_pca['PC1'], df_pca['PC2'])
plt.xlabel('Principal Component 1')
plt.ylabel('Principal Component 2')
plt.title('PCA on Iris Dataset')
plt.show()



Clustering 

 import pandas as pd
import matplotlib.pyplot as plt
import scipy.cluster.hierarchy as shc
from sklearn.cluster import AgglomerativeClustering

# Load dataset
df = pd.read_csv(r"C:\11.Spellman.csv.csv")

# Select gene expression columns (adjust if needed)
data = df.iloc[:, 3:5].values  

# Plot Dendrogram
plt.figure(figsize=(8,5))
shc.dendrogram(shc.linkage(data, method='ward'))
plt.title("Yeast Gene Expression Dendrogram")
plt.xlabel("Genes")
plt.ylabel("Distance")
plt.show()

# Apply Hierarchical Clustering
cluster = AgglomerativeClustering(n_clusters=5, linkage='ward')
labels = cluster.fit_predict(data)

# Visualize Clusters
plt.figure(figsize=(8,5))
plt.scatter(data[:,0], data[:,1], c=labels)
plt.title("Hierarchical Clustering of Yeast Data")
plt.xlabel("Expression 1")
plt.ylabel("Expression 2")
plt.show()
